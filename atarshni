<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>הרב אלדר לוי | הנהגה, הלכה וחסד בלב ערד</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@200;400;600;700;800&family=Frank+Ruhl+Libre:wght@300;500;700;900&family=Amiri:ital@0;1&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root { 
            --gold: #d4af37;
            --gold-light: #fef0c3;
            --gold-dark: #b89020;
            --gold-gradient: linear-gradient(135deg, #C59B3C, #FDF0B0, #9E7421, #FDF0B0, #C59B3C);
            --deep-navy: #060c1a;
            --paper: #fdfbf7;
            --text-dark: #1f2937;
            --glass: rgba(255, 255, 255, 0.85);
            --shadow-lux: 0 20px 40px rgba(0,0,0,0.06);
            --shadow-gold: 0 10px 30px rgba(212,175,55,0.2);
        }

        * { box-sizing: border-box; scroll-behavior: smooth; }
        ::selection { background: var(--gold-light); color: var(--deep-navy); }
        
        body { 
            font-family: 'Assistant', sans-serif; 
            margin: 0; 
            background: var(--paper); 
            color: var(--text-dark); 
            overflow-x: hidden;
            /* Subtle premium background pattern */
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23d4af37' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }

        h1, h2, h3 { font-family: 'Frank Ruhl Libre', serif; }

        @keyframes fadeInUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes bounce { 0%, 20%, 50%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-15px); } 60% { transform: translateY(-7px); } }
        @keyframes floating { 0% { transform: translateY(0px); } 50% { transform: translateY(-15px); } 100% { transform: translateY(0px); } }
        @keyframes subtleZoom { from { transform: scale(1); } to { transform: scale(1.05); } }

        .reveal { opacity: 0; transition: all 1s cubic-bezier(0.4, 0, 0.2, 1); transform: translateY(40px); }
        .reveal.visible { opacity: 1; transform: translateY(0); }
        .float { animation: floating 4s ease-in-out infinite; }

        .nav-glass {
            position: fixed; top: 25px; left: 50%; transform: translateX(-50%); width: 95%; max-width: 1200px;
            background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(212, 175, 55, 0.4); border-radius: 60px; padding: 15px 40px; display: flex;
            justify-content: space-between; align-items: center; z-index: 1000; box-shadow: var(--shadow-lux); transition: all 0.4s ease;
        }
        .nav-brand { display: flex; align-items: center; gap: 15px; text-decoration: none; color: var(--deep-navy); }
        .nav-brand img { width: 50px; height: 50px; object-fit: cover; border-radius: 50%; border: 2px solid var(--gold); box-shadow: 0 0 15px rgba(212,175,55,0.4); }
        .nav-brand span { font-weight: 800; font-size: 1.4rem; font-family: 'Frank Ruhl Libre', serif; }
        
        .nav-links { display: flex; gap: 30px; align-items: center; }
        .nav-links a { text-decoration: none; color: var(--text-dark); font-weight: 600; font-size: 1.05rem; transition: 0.3s; position: relative; }
        .nav-links a::after { content: ''; position: absolute; width: 0; height: 2px; bottom: -6px; right: 0; background: var(--gold-gradient); transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .nav-links a:hover::after { width: 100%; }
        .nav-links a:hover { color: var(--gold-dark); }
        
        .btn-contact { background: var(--gold-gradient) !important; color: var(--deep-navy) !important; padding: 10px 25px !important; border-radius: 30px !important; box-shadow: var(--shadow-gold); font-weight: 700 !important; }
        .btn-contact:hover { transform: translateY(-2px); box-shadow: 0 15px 35px rgba(212,175,55,0.3); }

        .mobile-toggle { display: none; font-size: 1.8rem; color: var(--deep-navy); cursor: pointer; }

        .mobile-menu { position: fixed; top: 0; right: -100%; width: 100vw; height: 100vh; background: rgba(5, 10, 20, 0.98); backdrop-filter: blur(15px); z-index: 2000; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 30px; transition: 0.5s cubic-bezier(0.77, 0, 0.175, 1); }
        .mobile-menu.active { right: 0; }
        .mobile-menu a { color: #fff; font-size: 2.2rem; text-decoration: none; font-family: 'Frank Ruhl Libre'; transition: 0.3s; }
        .mobile-menu a:hover { color: var(--gold); transform: scale(1.05); }
        .close-menu { position: absolute; top: 30px; left: 30px; color: white; font-size: 3rem; cursor: pointer; transition: 0.3s; }
        .close-menu:hover { color: var(--gold); transform: rotate(90deg); }

        .hero { height: 100vh; display: flex; align-items: center; justify-content: center; position: relative; color: white; text-align: center; background: #000; overflow: hidden; }
        .hero-video-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: url('https://www.deadsea.co.il/wp-content/uploads/2022/02/WhatsApp-Image-2022-02-08-at-13.30.31-2.jpeg') center/cover no-repeat; filter: brightness(0.5) contrast(1.1); transform: scale(1.1); transition: transform 0.1s; animation: subtleZoom 20s infinite alternate; }
        .hero-content { z-index: 10; max-width: 1000px; padding: 20px; }
        
        .hero-frame { border: 1px solid rgba(212, 175, 55, 0.3); padding: 60px; border-radius: 30px; background: linear-gradient(135deg, rgba(5,10,20,0.7), rgba(0,0,0,0.4)); backdrop-filter: blur(12px); position: relative; box-shadow: 0 30px 60px rgba(0,0,0,0.4), inset 0 0 30px rgba(212,175,55,0.1); }
        .hero-crown { position: absolute; top: -25px; left: 50%; transform: translateX(-50%); background: var(--gold-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-size: 2.5rem; filter: drop-shadow(0 5px 15px rgba(212,175,55,0.4)); }
        
        .hero-title { font-size: clamp(3.5rem, 9vw, 7.5rem); margin: 0; background: var(--gold-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 900; filter: drop-shadow(0 10px 20px rgba(0,0,0,0.6)); line-height: 1.1; }
        .hero-tagline { font-size: clamp(1.2rem, 3vw, 1.8rem); margin: 0 0 15px 0; font-weight: 400; letter-spacing: 5px; color: var(--gold-light); text-transform: uppercase; }
        .hero-subtitle { font-size: clamp(1.4rem, 4vw, 2rem); opacity: 0.9; text-shadow: 0 2px 4px rgba(0,0,0,0.5); font-weight: 300; margin-top: 25px; }
        .scroll-down { position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); font-size: 2.5rem; color: var(--gold); animation: bounce 2s infinite; cursor: pointer; z-index: 10; filter: drop-shadow(0 0 10px rgba(212,175,55,0.5)); }

        .timeline-section { padding: 120px 5%; background: transparent; position: relative; overflow: hidden; }
        .timeline { position: relative; max-width: 1000px; margin: 0 auto; }
        .timeline::after { content: ''; position: absolute; width: 4px; background: var(--gold-gradient); top: 0; bottom: 0; right: 50%; margin-right: -2px; border-radius: 2px; opacity: 0.5; box-shadow: 0 0 15px rgba(212,175,55,0.5); }
        .timeline-item { padding: 20px 40px; position: relative; width: 50%; box-sizing: border-box; }
        .timeline-item:nth-child(odd) { right: 0; text-align: left; }
        .timeline-item:nth-child(even) { right: 50%; text-align: right; }
        .timeline-item::after { content: ''; position: absolute; width: 28px; height: 28px; background: var(--paper); border: 5px solid var(--gold); top: 30px; border-radius: 50%; z-index: 1; box-shadow: 0 0 20px rgba(212,175,55,0.6); transition: 0.4s; }
        .timeline-item:hover::after { background: var(--gold-gradient); transform: scale(1.3); }
        .timeline-item:nth-child(odd)::after { left: -14px; }
        .timeline-item:nth-child(even)::after { right: -14px; }
        .timeline-content { padding: 40px; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); border-radius: 24px; box-shadow: var(--shadow-lux); border: 1px solid rgba(212,175,55,0.2); position: relative; transition: 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .timeline-content:hover { transform: translateY(-10px) scale(1.02); box-shadow: 0 25px 60px rgba(212,175,55,0.15); border-color: var(--gold); }
        .timeline-date { display: inline-block; padding: 8px 20px; background: linear-gradient(135deg, rgba(212,175,55,0.15), rgba(212,175,55,0.05)); color: var(--gold-dark); border-radius: 30px; font-weight: 800; font-size: 1.1rem; margin-bottom: 20px; font-family: 'Assistant', sans-serif; border: 1px solid rgba(212,175,55,0.2); }
        .timeline-content h3 { margin-top: 0; color: var(--deep-navy); font-size: 1.8rem; margin-bottom: 15px; font-weight: 800; }
        .timeline-content p { color: #555; line-height: 1.8; margin-bottom: 0; font-size: 1.15rem; }

        .weekly-pearl { padding: 100px 5%; background: linear-gradient(135deg, var(--deep-navy), #0a1128); color: white; position: relative; }
        .pearl-container { max-width: 1000px; margin: 0 auto; display: flex; gap: 40px; align-items: center; background: rgba(255,255,255,0.03); border: 1px solid rgba(212,175,55,0.3); padding: 60px; border-radius: 30px; backdrop-filter: blur(15px); box-shadow: 0 20px 50px rgba(0,0,0,0.3); position: relative; overflow: hidden; }
        .pearl-container::before { content: ''; position: absolute; top: 0; left: 0; width: 5px; height: 100%; background: var(--gold-gradient); }
        .pearl-icon { font-size: 5rem; color: var(--gold); opacity: 0.9; text-shadow: var(--shadow-gold); }
        .pearl-content h2 { color: var(--gold-light); font-size: 2.5rem; margin-top: 0; margin-bottom: 20px; }
        .pearl-content p { font-size: 1.35rem; line-height: 1.9; font-family: 'Amiri', serif; }

        .audio-section { padding: 100px 5%; background: transparent; }
        .audio-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px; max-width: 1100px; margin: 0 auto; }
        .audio-card { background: rgba(255,255,255,0.95); backdrop-filter: blur(10px); border-radius: 20px; padding: 20px 30px; display: flex; align-items: center; gap: 25px; box-shadow: var(--shadow-lux); border: 1px solid rgba(212,175,55,0.15); transition: 0.4s; }
        .audio-card:hover { transform: translateY(-8px); box-shadow: 0 20px 50px rgba(212,175,55,0.12); border-color: var(--gold); }
        .play-btn { width: 55px; height: 55px; border-radius: 50%; background: linear-gradient(135deg, #fef0c3, #fdfbf7); border: 2px solid var(--gold); color: var(--deep-navy); font-size: 1.4rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.4s; flex-shrink: 0; box-shadow: 0 5px 15px rgba(212,175,55,0.2); }
        .play-btn:hover { background: var(--gold-gradient); color: white; transform: scale(1.1); box-shadow: 0 10px 25px rgba(212,175,55,0.4); border-color: transparent; }
        .audio-info { flex-grow: 1; }
        .audio-info h4 { margin: 0 0 5px 0; color: var(--deep-navy); font-size: 1.2rem; font-weight: 700; }
        .audio-info p { margin: 0; color: #777; font-size: 1rem; }
        .audio-duration { font-size: 0.9rem; color: var(--gold-dark); font-weight: bold; background: rgba(212,175,55,0.1); padding: 5px 12px; border-radius: 20px; }

        .services { padding: 120px 5%; background: transparent; }
        .section-title { text-align: center; margin-bottom: 70px; }
        .section-title h2 { font-size: clamp(2.8rem, 6vw, 4rem); color: var(--deep-navy); margin-bottom: 15px; }
        .section-title .line { width: 100px; height: 5px; background: var(--gold-gradient); margin: 0 auto; border-radius: 3px; box-shadow: 0 5px 15px rgba(212,175,55,0.3); }
        .section-title p { color: #666; font-size: 1.3rem; margin-top: 20px; font-weight: 500; }
        
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 40px; max-width: 1200px; margin: 0 auto; }
        .card { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); padding: 50px 30px; border-radius: 24px; text-align: center; transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); border: 1px solid rgba(212, 175, 55, 0.15); box-shadow: var(--shadow-lux); position: relative; z-index: 1; overflow: hidden; }
        .card::after { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 5px; background: var(--gold-gradient); transition: 0.5s ease; opacity: 0.8; }
        .card:hover { transform: translateY(-15px); box-shadow: 0 30px 60px rgba(212,175,55,0.15); border-color: rgba(212, 175, 55, 0.4); }
        .card:hover::after { height: 100%; opacity: 0.05; }
        .card i { font-size: 3.5rem; background: var(--gold-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 25px; transition: 0.4s; filter: drop-shadow(0 5px 10px rgba(212,175,55,0.2)); }
        .card:hover i { transform: scale(1.15) translateY(-5px); }
        .card h3 { font-size: 1.8rem; color: var(--deep-navy); margin-bottom: 15px; font-weight: 800; }
        .card p { color: #555; line-height: 1.7; font-size: 1.1rem; }

        .letter-section { padding: 120px 10%; background: linear-gradient(rgba(253, 251, 247, 0.96), rgba(253, 251, 247, 0.96)), url('https://www.deadsea.co.il/wp-content/uploads/2022/02/WhatsApp-Image-2022-02-08-at-13.30.31-2.jpeg') center/cover fixed; display: flex; align-items: center; gap: 70px; }
        .portrait-container { flex: 1; position: relative; }
        .portrait-container img { width: 100%; border-radius: 20px; box-shadow: 30px 30px 0 rgba(212,175,55,0.8), 0 20px 50px rgba(0,0,0,0.2); transition: 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .portrait-container:hover img { transform: translate(-10px, -10px); box-shadow: 40px 40px 0 rgba(5,10,20,0.9), 0 30px 60px rgba(0,0,0,0.3); }
        .letter-content { flex: 1.5; font-family: 'Amiri', serif; font-size: 1.45rem; line-height: 2.2; color: #222; }
        .letter-content b { color: var(--gold-dark); font-size: 1.6rem; }
        .book-highlight { margin: 35px 0; padding: 30px; background: rgba(255,255,255,0.8); backdrop-filter: blur(10px); border-radius: 20px; border-right: 5px solid var(--gold); display: flex; gap: 25px; align-items: center; box-shadow: var(--shadow-lux); transition: 0.4s; }
        .book-highlight:hover { transform: translateX(-10px); border-color: var(--deep-navy); }

        .testimonials { padding: 120px 5%; background: transparent; }
        .testimo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 40px; max-width: 1200px; margin: 50px auto 0; }
        .testimo-card { background: rgba(255,255,255,0.95); backdrop-filter: blur(10px); padding: 50px; border-radius: 24px; position: relative; border: 1px solid rgba(212,175,55,0.15); box-shadow: var(--shadow-lux); transition: 0.4s; }
        .testimo-card:hover { transform: translateY(-10px); box-shadow: 0 25px 50px rgba(212,175,55,0.15); border-color: var(--gold); }
        .testimo-card i.fa-quote-right { position: absolute; top: 30px; right: 30px; font-size: 4rem; color: var(--gold); opacity: 0.15; }
        .testimo-text { font-family: 'Amiri', serif; font-size: 1.3rem; color: #333; line-height: 1.8; margin-bottom: 25px; position: relative; z-index: 2; }
        .testimo-author { font-weight: 800; color: var(--deep-navy); border-top: 2px solid var(--gold-light); padding-top: 15px; display: inline-block; font-size: 1.1rem; }

        .gallery-container { padding: 100px 0; background: var(--deep-navy); overflow: hidden; position: relative; }
        .gallery-container::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 5px; background: var(--gold-gradient); }
        .gallery-track { display: flex; overflow-x: auto; gap: 20px; padding: 30px 5%; scroll-behavior: smooth; -webkit-overflow-scrolling: touch; }
        .gallery-track::-webkit-scrollbar { height: 8px; }
        .gallery-track::-webkit-scrollbar-track { background: rgba(255,255,255,0.05); border-radius: 10px; }
        .gallery-track::-webkit-scrollbar-thumb { background: var(--gold-gradient); border-radius: 10px; }
        .gallery-item { min-width: 350px; height: 450px; position: relative; cursor: pointer; border-radius: 20px; overflow: hidden; box-shadow: 0 15px 30px rgba(0,0,0,0.4); border: 1px solid rgba(212,175,55,0.2); }
        .gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275); filter: brightness(0.8) sepia(10%); }
        .gallery-item:hover img { filter: brightness(1.1) sepia(0); transform: scale(1.1); }
        .gallery-overlay { position: absolute; bottom: -80px; left: 0; width: 100%; background: linear-gradient(transparent, rgba(5,10,20,0.95)); color: white; padding: 40px 25px 25px; text-align: center; transition: 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); font-size: 1.2rem; font-weight: 700; border-bottom: 4px solid var(--gold); }
        .gallery-item:hover .gallery-overlay { bottom: 0; }

        .lightbox { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(5, 10, 20, 0.98); backdrop-filter: blur(10px); z-index: 3000; display: none; justify-content: center; align-items: center; opacity: 0; transition: opacity 0.4s; }
        .lightbox.active { display: flex; opacity: 1; }
        .lightbox img { max-width: 90%; max-height: 90%; border-radius: 15px; box-shadow: 0 0 60px rgba(212,175,55,0.2); border: 2px solid var(--gold); }
        .lightbox-close { position: absolute; top: 40px; right: 50px; color: white; font-size: 3rem; cursor: pointer; transition: 0.3s; }
        .lightbox-close:hover { color: var(--gold); transform: rotate(90deg) scale(1.1); }

        .faq-section { padding: 120px 5%; background: transparent; }
        .faq-container { max-width: 900px; margin: 0 auto; background: rgba(255,255,255,0.95); backdrop-filter: blur(10px); border-radius: 24px; padding: 40px; box-shadow: var(--shadow-lux); border: 1px solid rgba(212,175,55,0.15); }
        .faq-item { border-bottom: 1px solid rgba(0,0,0,0.05); margin-bottom: 15px; }
        .faq-item:last-child { border-bottom: none; margin-bottom: 0; }
        .faq-question { width: 100%; text-align: right; background: none; border: none; padding: 25px 15px; font-size: 1.3rem; font-family: 'Assistant', sans-serif; font-weight: 800; color: var(--deep-navy); cursor: pointer; display: flex; justify-content: space-between; align-items: center; transition: 0.3s; border-radius: 15px; }
        .faq-question:hover { color: var(--gold-dark); background: rgba(212,175,55,0.03); padding-right: 25px; }
        .faq-question i { color: var(--gold-dark); transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1); background: rgba(212,175,55,0.1); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: inset 0 0 10px rgba(255,255,255,0.5); }
        .faq-question.active i { transform: rotate(180deg); background: var(--gold-gradient); color: white; box-shadow: 0 5px 15px rgba(212,175,55,0.4); }
        .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
        .faq-answer-content { padding: 0 15px 30px; color: #555; line-height: 1.8; font-size: 1.15rem; }

        .contact-box { max-width: 1100px; margin: -80px auto 100px; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(15px); display: flex; border-radius: 30px; box-shadow: 0 40px 80px rgba(0,0,0,0.1); overflow: hidden; z-index: 100; position: relative; border: 1px solid rgba(212, 175, 55, 0.2); }
        .contact-info { background: var(--gold-gradient); padding: 70px; flex: 1; color: var(--deep-navy); position: relative; overflow: hidden; }
        .contact-info::after { content: '\f65e'; font-family: 'Font Awesome 6 Free'; font-weight: 900; position: absolute; bottom: -30px; right: -30px; font-size: 18rem; opacity: 0.08; pointer-events: none; transform: rotate(-15deg); }
        .contact-form { padding: 70px; flex: 1.5; }
        input, textarea { width: 100%; padding: 18px 25px; margin-bottom: 25px; border: 2px solid #eaeaea; border-radius: 15px; font-family: inherit; font-size: 1.1rem; background: #fafafa; transition: 0.3s; }
        input:focus, textarea:focus { outline: none; border-color: var(--gold); background: white; box-shadow: 0 0 15px rgba(212,175,55,0.15); }
        .btn-submit { background: var(--deep-navy); color: var(--gold-light); padding: 20px 40px; border: none; border-radius: 15px; font-weight: 800; font-size: 1.2rem; cursor: pointer; transition: 0.4s; width: 100%; display: flex; justify-content: center; align-items: center; gap: 12px; }
        .btn-submit:hover { background: #000; transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.3); color: white; }
        .whatsapp-join { margin-top: 30px; display: inline-flex; align-items: center; gap: 10px; background: #25D366; color: white; padding: 15px 30px; border-radius: 50px; text-decoration: none; font-weight: bold; transition: 0.4s; font-size: 1.1rem; box-shadow: 0 10px 20px rgba(37, 211, 102, 0.3); border: 2px solid transparent; }
